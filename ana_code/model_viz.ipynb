   "source": [
    "import os\n",
    "import math\n",
    "from pyspark.sql import SparkSession, Row\n",
    "from pyspark.ml import PipelineModel\n",
    "from ipyleaflet import Map, basemaps, Marker, FullScreenControl\n",
    "from ipywidgets import Output, VBox\n",
    "\n",
    "spark = SparkSession.builder \\\n",
    "    .appName(\"NYC_Transport_Final\") \\\n",
    "    .getOrCreate()\n",
    "\n",
    "spark.sparkContext.setLogLevel(\"ERROR\")\n",
    "\n",
    "model_path = \""\"",
    "\n",
    "model = PipelineModel.load(model_path)\n",
    "\n",
    "m = Map(\n",
    "    basemap=basemaps.CartoDB.Positron, \n",
    "    center=(40.745, -73.948), \n",
    "    zoom=12\n",
    ")\n",
    "m.add_control(FullScreenControl())\n",
    "\n",
    "out = Output(layout={'border': '2px solid #444', 'height': '180px', 'overflow_y': 'scroll'})\n",
    "click_points = []\n",
    "\n",
    "def handle_click(**kwargs):\n",
    "    global click_points\n",
    "    with out:\n",
    "        if kwargs.get('type') == 'click':\n",
    "            loc = kwargs.get('coordinates')\n",
    "            \n",
    "            if len(click_points) == 0:\n",
    "                out.clear_output()\n",
    "                m.layers = [m.layers[0]] \n",
    "            \n",
    "            click_points.append(loc)\n",
    "            \n",
    "            new_marker = Marker(location=loc)\n",
    "            m.add_layer(new_marker)\n",
    "            \n",
    "            #print(f\"Point {len(click_points)}: {loc}\")\n",
    "            \n",
    "            if len(click_points) == 2:\n",
    "                p1, p2 = click_points[0], click_points[1]\n",
    "                \n",
    "                R = 3958.8\n",
    "                lat1, lon1, lat2, lon2 = map(math.radians, [p1[0], p1[1], p2[0], p2[1]])\n",
    "                d = 2 * R * math.asin(math.sqrt(math.sin((lat2-lat1)/2)**2 + \n",
    "                    math.cos(lat1)*math.cos(lat2)*math.sin((lon2-lon1)/2)**2))\n",
    "                \n",
    "                test_row = Row(\n",
    "                    \n",
    "                    start_longitude=float(p1[1]), \n",
    "                    start_latitude=float(p1[0]),\n",
    "                    distance=float(d), \n",
    "                    #0-23\n",
    "                    time_hours=12,\n",
    "                    temp_f=70.0, \n",
    "                    #0.0 to 20.0\n",
    "                    precipitation_mm=0.0, \n",
    "                    #\"SPRING\", \"SUMMER\", \"AUTUMN\", \"WINTER\"\n",
    "                    season=\"SPRING\", \n",
    "                    #\"0 - Calm\", \"1 - Light Air\", \"2 - Light Breeze\", \"3 - Gentle Breeze\", \"4 - Moderate Breeze\", \"5 - Fresh Breeze\", \"6 - Strong Breeze\"\n",
    "                    beaufort_scale=\"2 - Light Breeze\",\n",
    "                    \n",
    "                    \n",
    "                    #is_taxi=0,\n",
    "                    #rain_mm=0.0,\n",
    "                    #cloudcover_pct=10.0, \n",
    "                    #windspeed_kmh=10.0, \n",
    "                    #wind_direction_deg=180.0,\n",
    "                    #date=\"2019-03-01\", \n",
    "                    #isHot=0, \n",
    "                    #isWindy=0\n",
    "                    #trip_duration=50.0, \n",
    "                )\n",
    "                \n",
    "                input_df = spark.createDataFrame([test_row])\n",
    "                prediction_df = model.transform(input_df)\n",
    "                results = prediction_df.collect()\n",
    "                \n",
    "                out.clear_output(wait=True)\n",
    "                print(f\"Starting Point: {p1}\")\n",
    "                print(f\"Ending Point: {p2}\")\n",
    "                \n",
    "                if results:\n",
    "                    res = results[0]\n",
    "                    mode = \"YELLOW TAXI\" if res.prediction == 1.0 else \"CITIBIKE\"\n",
    "                    print(f\"Distance: {d:.2f} miles\")\n",
    "                    print(f\"Predicted Mode: {mode}\")\n",
    "                else:\n",
    "                    print(\"Prediction failed\")\n",
    "                \n",
    "                click_points = []\n",
    "\n",
    "m.on_interaction(handle_click)\n",
    "display(VBox([m, out]))"
   ]
  }
 ],
